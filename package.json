{
  "name": "mediadb",
  "version": "0.6.0",
  "private": true,
  "description": "manager for movie and tv shows",
  "type": "module",
  "scripts": {
    "build": "tauri build",
    "build-debug": "tauri build --debug",
    "dev": "__NV_DISABLE_EXPLICIT_SYNC=1  tauri dev",
    "lint": "biome check --write . && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "prepare": "husky",
    "tauri": "tauri",
    "test": "vitest run && cargo test --manifest-path src-tauri/Cargo.toml",
    "type-check": "tsc --pretty --noEmit",
    "vite-build": "tsc && vite build",
    "vite-dev": "vite"
  },
  "dependencies": {
    "@solid-primitives/scheduled": "1.5.3",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/solid-form": "1.29.1",
    "@tanstack/solid-query": "5.100.9",
    "@tanstack/solid-router": "1.169.1",
    "@tanstack/solid-store": "0.11.0",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-opener": "2.5.4",
    "clsx": "2.1.1",
    "daisyui": "5.5.19",
    "immutable": "5.1.5",
    "solid-js": "1.9.12",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tanstack/router-plugin": "1.167.32",
    "@tanstack/solid-query-devtools": "5.100.9",
    "@tanstack/solid-router-devtools": "1.166.13",
    "@tauri-apps/cli": "2.11.0",
    "@types/node": "24.12.2",
    "husky": "9.1.7",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
