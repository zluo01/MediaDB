{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableDependencyDashboard"],
  "schedule": ["every weekend"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "groupName": "tauri",
      "matchPackageNames": ["@tauri-apps/*"]
    },
    {
      "groupName": "tanstack",
      "matchPackageNames": ["@tanstack/*"]
    },
    {
      "groupName": "solidjs",
      "matchPackageNames": ["solid-js", "@solid-primitives/*", "vite-plugin-solid"]
    },
    {
      "groupName": "styling",
      "matchPackageNames": [
        "@tailwindcss/*",
        "tailwindcss",
        "tailwindcss-animate",
        "tailwind-merge",
        "daisyui",
        "clsx"
      ]
    },
    {
      "groupName": "tooling",
      "matchPackageNames": ["vite", "vitest", "typescript", "@biomejs/*", "husky", "@types/*"]
    },
    {
      "groupName": "utilities",
      "matchPackageNames": ["immutable", "zod"]
    }
  ],
  "postUpdateOptions": ["pnpmDedupe"]
}
